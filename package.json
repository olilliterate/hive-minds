  },
  "homepage": "https://github.com/olilliterate/hive-minds#readme",
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-each": "^28.1.3",
    "jsdom": "^29.0.1",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs": "^0.0.1-security",
