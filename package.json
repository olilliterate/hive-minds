{
  "name": "hive-minds",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "setup-db": "node ./server/db/setup.js",
    "test": "jest --watchAll --detectOpenHandles --runInBand --verbose",
    "setup-test-db": "NODE_ENV=test node ./database/setup.js",
    "unitTests": "jest --testPathPattern=/unit/ --watchAll --verbose",
    "integrationTests": "jest --testPathPatterns=/integration/ --watchAll --detectOpenHandles --runInBand --verbose",
    "coverage": "jest --coverage --testPathPatterns=/unit/"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "./__tests__/integration/config.js"
    ]
  },
